# Crypto Trading Agent v9.0 Configuration
# Copy this file to .env and fill in your values
# NEVER commit your .env file to version control

# ============================================================
# EXCHANGE API CREDENTIALS
# ============================================================
EXCHANGE_ID=binance
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
# Ed25519 key path (Binance only, optional — use HMAC secret if not set)
# API_PRIVATE_KEY_PATH=./binance_api_private.pem

# ============================================================
# TRADING CONFIGURATION
# ============================================================
TRADING_PAIR=BTC/USDT
TRADING_PAIRS=BTC/USDT
# For multi-pair portfolio trading, comma-separate pairs:
# TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT
TIMEFRAME=1h
CONFIRMATION_TIMEFRAME=4h
INITIAL_CAPITAL=1000

# Risk management
# Constraint: MAX_POSITION_PCT * MAX_OPEN_POSITIONS must be <= 1.0
MAX_POSITION_PCT=0.02
MAX_OPEN_POSITIONS=3
# Constraint: STOP_LOSS_PCT must be < TAKE_PROFIT_PCT
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.05
TRAILING_STOP_PCT=0.015
MAX_HOLD_BARS=100

# Transaction costs
# Constraint: FEE_PCT + SLIPPAGE_PCT must be < STOP_LOSS_PCT
FEE_PCT=0.001
SLIPPAGE_PCT=0.0005

# Mode: paper or live (live requires API_KEY and API_SECRET)
TRADING_MODE=paper

# Agent cycle interval (seconds) — minimum 10 to avoid exchange rate limits
AGENT_INTERVAL_SECONDS=300

# ============================================================
# WEBSOCKET STREAMING (real-time data)
# ============================================================
# Enable for lower latency — replaces polling with persistent connections
# Supports: binance, kraken, coinbase, bybit
ENABLE_WEBSOCKET=false

# ============================================================
# INTELLIGENCE MODULES
# ============================================================
# On-chain analysis (Blockchain.com + Mempool.space — free, no key)
ENABLE_ONCHAIN=false

# Whale transaction tracking (Blockchain.com — free, no key)
ENABLE_WHALE_TRACKING=false

# News sentiment (Reddit + CoinGecko — free, no key)
# Optional: add CryptoPanic API key for more data
ENABLE_NEWS_NLP=false
CRYPTOPANIC_API_KEY=

# Stock market correlation (Yahoo Finance — free, no key)
ENABLE_CORRELATION=false

# Order book depth analysis (uses exchange API)
ENABLE_ORDERBOOK=false

# Funding rate & Open Interest analysis (uses exchange API)
ENABLE_FUNDING_OI=false

# Liquidation data tracking (uses exchange API)
ENABLE_LIQUIDATION=false

# How often to refresh intelligence (seconds)
INTELLIGENCE_INTERVAL_SECONDS=300

# ============================================================
# NOTIFICATIONS & ALERTS
# ============================================================
# Telegram (create bot via @BotFather, get chat_id via @userinfobot)
# Both TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID must be set together.
# Setting only one will trigger a startup warning.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Webhook (for receiving Telegram commands — requires ngrok or public URL)
# TELEGRAM_WEBHOOK_URL=https://your-domain.ngrok-free.dev/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=your-secret-here
# Trade confirmation (requires webhook to be set up)
TELEGRAM_TRADE_CONFIRMATION=false
TELEGRAM_CONFIRMATION_TIMEOUT=60
TELEGRAM_CONFIRMATION_DEFAULT=reject

# Discord (create webhook in channel settings -> Integrations)
DISCORD_WEBHOOK_URL=

# Email (only for critical alerts and daily summaries)
EMAIL_ALERTS_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=

# ============================================================
# TRADE DATABASE
# ============================================================
ENABLE_TRADE_DB=true
# TRADE_DB_PATH=./trades.db  # Default: DATA_DIR/trades.db

# ============================================================
# RATE LIMITING
# ============================================================
MAX_REQUESTS_PER_MINUTE=1200
MAX_ORDERS_PER_MINUTE=10

# ============================================================
# API SERVER
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
ENABLE_API=true

# API authentication key (empty = no auth, for development only)
# Set this in production to secure the API and WebSocket endpoints.
# REST: send X-API-Key header. WebSocket: send {"type":"auth","api_key":"xxx"} after connecting.
API_AUTH_KEY=

# CORS allowed origins (comma-separated). Default: localhost only.
# In Docker or production, add your dashboard's actual origin.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================
# ARBITRAGE (multi-exchange)
# ============================================================
ARBITRAGE_ENABLED=false
ARBITRAGE_INTERVAL_SECONDS=60
ARBITRAGE_CAPITAL_PCT=0.1
ARBITRAGE_MIN_SPREAD_PCT=0.003
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# COINBASE_API_KEY=
# COINBASE_API_SECRET=
# KRAKEN_API_KEY=
# KRAKEN_API_SECRET=

# ============================================================
# MONTE CARLO RISK SIMULATION
# ============================================================
MC_SIMULATIONS=10000
MC_HORIZON_DAYS=252

# ============================================================
# DATA & LOGGING
# ============================================================
DATA_DIR=.
LOG_LEVEL=INFO
# LOG_FILE=./agent.log
# STATE_FILE=./agent_state.json

# ============================================================
# MODEL
# ============================================================
MODEL_RETRAIN_HOURS=24
# Range: (0, 1.0] — values below 0.4 trigger a startup warning
MIN_CONFIDENCE=0.65
DRIFT_THRESHOLD=0.15
ML_LABEL_THRESHOLD=0.005

# ============================================================
# VALIDATION NOTES
# ============================================================
# The agent validates all configuration at startup. Hard failures
# prevent the agent from starting; warnings are logged but allowed.
#
# HARD FAILURES (agent will not start):
#   - INITIAL_CAPITAL must be > 0
#   - 0 < STOP_LOSS_PCT < 1 and 0 < TAKE_PROFIT_PCT < 1
#   - STOP_LOSS_PCT < TAKE_PROFIT_PCT
#   - FEE_PCT + SLIPPAGE_PCT < STOP_LOSS_PCT
#   - MAX_POSITION_PCT * MAX_OPEN_POSITIONS <= 1.0
#   - 0 < MIN_CONFIDENCE <= 1.0
#   - AGENT_INTERVAL_SECONDS >= 10
#   - Live mode requires API_KEY and API_SECRET
#
# WARNINGS (agent starts but logs a warning):
#   - MIN_CONFIDENCE < 0.4 (may generate low-quality signals)
#   - FEE_PCT + SLIPPAGE_PCT > 50% of STOP_LOSS_PCT
#   - MAX_POSITION_PCT * MAX_OPEN_POSITIONS > 0.8 (high allocation)
#   - TELEGRAM_BOT_TOKEN set without TELEGRAM_CHAT_ID (or vice versa)

# ============================================================
# PHASE 10: ADVANCED EXECUTION (OPTIONAL)
# ============================================================
# Phase 10: Perp executor (optional)
USE_PERP=false
PERP_LEVERAGE=3

# Phase 10: WebSocket real-time kline feed (optional)
USE_WS_FEED=false
